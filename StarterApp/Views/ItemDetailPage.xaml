<?xml version="1.0" encoding="utf-8" ?>
<ContentPage x:Class="StarterApp.Views.ItemDetailPage"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:StarterApp.ViewModels"
             x:DataType="vm:ItemDetailViewModel"
             Title="{Binding Title}">

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="Edit"
                     Command="{Binding EditItemCommand}"
                     IsVisible="{Binding IsOwner}" />
    </ContentPage.ToolbarItems>

    <ScrollView>
        <Grid Padding="20" RowSpacing="15">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Loading -->
            <ActivityIndicator Grid.Row="0"
                               IsVisible="{Binding IsBusy}"
                               IsRunning="{Binding IsBusy}"
                               HorizontalOptions="Center" />

            <!-- Error Banner -->
            <Border Grid.Row="1"
                    BackgroundColor="{AppThemeBinding Light=#FFEBEE, Dark=#1B0000}"
                    Stroke="{AppThemeBinding Light=#F44336, Dark=#EF5350}"
                    StrokeThickness="1"
                    Padding="15"
                    IsVisible="{Binding HasError}">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="8" />
                </Border.StrokeShape>
                <Label Text="{Binding ErrorMessage}"
                       TextColor="{AppThemeBinding Light=#D32F2F, Dark=#EF5350}"
                       FontSize="14" />
            </Border>

            <!-- Item Card -->
            <Border Grid.Row="2"
                    BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray900}}"
                    Stroke="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray700}}"
                    StrokeThickness="1"
                    Padding="20">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="12" />
                </Border.StrokeShape>
                <StackLayout Spacing="12">
                    <Label Text="{Binding Item.Title}"
                           FontSize="22"
                           FontAttributes="Bold" />
                    <Label Text="{Binding Item.FormattedRate}"
                           FontSize="20"
                           FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}" />
                    <Label Text="{Binding Item.Category}"
                           FontSize="14"
                           TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray400}}" />
                    <BoxView HeightRequest="1" />
                    <Label Text="Description"
                           FontSize="14"
                           FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray400}}" />
                    <Label Text="{Binding Item.Description}"
                           FontSize="14" />
                    <BoxView HeightRequest="1" />
                    <Grid ColumnDefinitions="*,*">
                        <StackLayout Grid.Column="0" Spacing="4">
                            <Label Text="Owner"
                                   FontSize="12"
                                   TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray400}}" />
                            <Label Text="{Binding Item.OwnerName}"
                                   FontSize="14"
                                   FontAttributes="Bold" />
                        </StackLayout>
                        <StackLayout Grid.Column="1" Spacing="4">
                            <Label Text="Availability"
                                   FontSize="12"
                                   TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray400}}" />
                            <Label Text="{Binding Item.AvailabilityText}"
                                   FontSize="14"
                                   FontAttributes="Bold" />
                        </StackLayout>
                    </Grid>
                </StackLayout>
            </Border>

            <!-- Rent Button -->
            <Button Grid.Row="3"
                    Text="Request Rental"
                    Command="{Binding RentItemCommand}"
                    BackgroundColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                    TextColor="White"
                    HeightRequest="50"
                    CornerRadius="8"
                    FontSize="16"
                    FontAttributes="Bold"
                    IsVisible="{Binding IsOwner, Converter={StaticResource InvertedBoolConverter}}" />
        </Grid>
    </ScrollView>
</ContentPage>
