<?xml version="1.0" encoding="utf-8" ?>
<ContentPage x:Class="StarterApp.Views.RentalListPage"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:StarterApp.ViewModels"
             xmlns:models="clr-namespace:StarterApp.Models"
             x:DataType="vm:RentalListViewModel"
             Title="{Binding Title}">

    <Grid RowDefinitions="Auto,Auto,*">

        <!-- Tab Buttons -->
        <Grid Grid.Row="0" ColumnDefinitions="*,*" Padding="20,10">
            <Button Grid.Column="0"
                    Text="Incoming"
                    Command="{Binding ShowIncomingTabCommand}"
                    BackgroundColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                    TextColor="White"
                    CornerRadius="8"
                    FontSize="14"
                    Margin="0,0,5,0" />
            <Button Grid.Column="1"
                    Text="Outgoing"
                    Command="{Binding ShowOutgoingTabCommand}"
                    BackgroundColor="Transparent"
                    TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                    BorderWidth="1"
                    BorderColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                    CornerRadius="8"
                    FontSize="14"
                    Margin="5,0,0,0" />
        </Grid>

        <!-- Error Banner -->
        <Border Grid.Row="1"
                BackgroundColor="{AppThemeBinding Light=#FFEBEE, Dark=#1B0000}"
                Stroke="{AppThemeBinding Light=#F44336, Dark=#EF5350}"
                StrokeThickness="1"
                Padding="15"
                Margin="20,0"
                IsVisible="{Binding HasError}">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="8" />
            </Border.StrokeShape>
            <Label Text="{Binding ErrorMessage}"
                   TextColor="{AppThemeBinding Light=#D32F2F, Dark=#EF5350}"
                   FontSize="14" />
        </Border>

        <!-- Incoming List -->
        <RefreshView Grid.Row="2"
                     IsRefreshing="{Binding IsRefreshing}"
                     Command="{Binding RefreshCommand}"
                     IsVisible="{Binding ShowIncoming}">
            <CollectionView ItemsSource="{Binding IncomingRentals}" SelectionMode="None">
                <CollectionView.EmptyView>
                    <Label Text="No incoming rental requests"
                           FontSize="16"
                           TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray400}}"
                           HorizontalOptions="Center"
                           Margin="0,40" />
                </CollectionView.EmptyView>
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:Rental">
                        <Border Margin="20,6"
                                Padding="20"
                                BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray900}}"
                                Stroke="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray700}}"
                                StrokeThickness="1">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="12" />
                            </Border.StrokeShape>
                            <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto">
                                <Label Grid.Row="0" Grid.Column="0"
                                       Text="{Binding ItemTitle}"
                                       FontSize="16"
                                       FontAttributes="Bold" />
                                <Label Grid.Row="0" Grid.Column="1"
                                       Text="{Binding StatusDisplay}"
                                       FontSize="13"
                                       TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}" />
                                <Label Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                                       Text="{Binding BorrowerName, StringFormat='From: {0}'}"
                                       FontSize="13"
                                       TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray400}}"
                                       Margin="0,4,0,0" />
                                <Label Grid.Row="2" Grid.Column="0"
                                       Text="{Binding DateRange}"
                                       FontSize="12"
                                       TextColor="{AppThemeBinding Light={StaticResource Gray400}, Dark={StaticResource Gray500}}"
                                       Margin="0,4,0,0" />
                                <Label Grid.Row="2" Grid.Column="1"
                                       Text="{Binding FormattedPrice}"
                                       FontSize="14"
                                       FontAttributes="Bold"
                                       Margin="0,4,0,0" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </RefreshView>

        <!-- Outgoing List -->
        <RefreshView Grid.Row="2"
                     IsRefreshing="{Binding IsRefreshing}"
                     Command="{Binding RefreshCommand}"
                     IsVisible="{Binding ShowIncoming, Converter={StaticResource InvertedBoolConverter}}">
            <CollectionView ItemsSource="{Binding OutgoingRentals}" SelectionMode="None">
                <CollectionView.EmptyView>
                    <Label Text="No outgoing rental requests"
                           FontSize="16"
                           TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray400}}"
                           HorizontalOptions="Center"
                           Margin="0,40" />
                </CollectionView.EmptyView>
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:Rental">
                        <Border Margin="20,6"
                                Padding="20"
                                BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray900}}"
                                Stroke="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray700}}"
                                StrokeThickness="1">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="12" />
                            </Border.StrokeShape>
                            <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto">
                                <Label Grid.Row="0" Grid.Column="0"
                                       Text="{Binding ItemTitle}"
                                       FontSize="16"
                                       FontAttributes="Bold" />
                                <Label Grid.Row="0" Grid.Column="1"
                                       Text="{Binding StatusDisplay}"
                                       FontSize="13"
                                       TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}" />
                                <Label Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                                       Text="{Binding OwnerName, StringFormat='Owner: {0}'}"
                                       FontSize="13"
                                       TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray400}}"
                                       Margin="0,4,0,0" />
                                <Label Grid.Row="2" Grid.Column="0"
                                       Text="{Binding DateRange}"
                                       FontSize="12"
                                       TextColor="{AppThemeBinding Light={StaticResource Gray400}, Dark={StaticResource Gray500}}"
                                       Margin="0,4,0,0" />
                                <Label Grid.Row="2" Grid.Column="1"
                                       Text="{Binding FormattedPrice}"
                                       FontSize="14"
                                       FontAttributes="Bold"
                                       Margin="0,4,0,0" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </RefreshView>

        <ActivityIndicator Grid.Row="2"
                           IsVisible="{Binding IsBusy}"
                           IsRunning="{Binding IsBusy}"
                           VerticalOptions="Center"
                           HorizontalOptions="Center" />
    </Grid>
</ContentPage>
